{
  "name": "sift-frontend",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:mvp",
    "dev:mvp": "VITE_APP_MODE=mvp vite",
    "dev:admin": "VITE_APP_MODE=admin vite --port 5174",
    "dev:sne": "VITE_APP_MODE=admin vite --port 5175 --open /admin/neural",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-force-graph-3d": "^1.29.1",
    "react-router-dom": "^6.28.0",
    "three": "^0.184.0",
    "three-spritetext": "^1.10.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}

{
  "name": "sift",
  "private": true,
  "version": "0.4.0",
  "scripts": {
    "mvp": "python3 tools/sift_app.py --build",
    "mvp:api": "python3 tools/sift_app.py --build --no-ollama",
    "mvp:lan": "python3 tools/sift_app.py --host 0.0.0.0 --build",
    "admin": "python3 tools/sift_app.py --build --admin",
    "dev": "concurrently \"uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000\" \"npm --prefix frontend run dev -- --host 127.0.0.1 --port 5173 --strictPort\"",
    "dev:backend": "uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev -- --host 127.0.0.1 --port 5173 --strictPort",
    "build": "npm --prefix frontend run build",
    "knowledge:vc": "./.venv/bin/python scripts/build_vc_firm_cluster.py",
    "brain:update": "./.venv/bin/python scripts/update_knowledge_graph.py",
    "brain:train": "./.venv/bin/python scripts/train_sift_brain.py",
    "brain:serve": "./.venv/bin/python scripts/serve_sift_brain.py"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}

# Runtime mode
SIFT_MODEL_PROVIDER=ollama
SIFT_ENABLE_OLLAMA=true
SIFT_ENABLE_LOCAL_OPENAI=true
SIFT_ENABLE_OPEN_SOURCE_PROVIDER=false
SIFT_PERSISTENCE_BACKEND=sqlite
SIFT_DATA_DIR=data
SIFT_DATABASE_URL=
SIFT_DATABASE_TOKEN=
SIFT_EXPERT_DATA_DIR=knowledge_base/expert
SIFT_UPLOAD_BACKEND=local
SIFT_UPLOAD_BUCKET=
SIFT_UPLOAD_PREFIX=session_uploads
SIFT_UPLOAD_TMP_DIR=
SIFT_ADMIN_TOKEN=
SIFT_SESSION_SECRET=change-me-for-shared-use
SIFT_COOKIE_SECURE=false
SIFT_COOKIE_SAMESITE=lax
SIFT_CORS_ORIGINS=
SIFT_FRONTEND_URL=

# Google Cloud serverless deployment
SIFT_GCP_PROJECT_ID=
SIFT_FIRESTORE_DATABASE=
SIFT_FIRESTORE_COLLECTION_PREFIX=sift
SIFT_BIGQUERY_ENABLED=false
SIFT_BIGQUERY_TABLE=
SIFT_BIGQUERY_DATASET=
SIFT_BIGQUERY_EVENTS_TABLE=events
VERTEX_LOCATION=us-central1
VERTEX_MODEL_SPEED=gemini-2.5-flash
VERTEX_MODEL_BALANCED=gemini-2.5-pro

# Frontend deployment
# Set this on Vercel when the frontend is deployed separately from the FastAPI backend.
VITE_API_BASE_URL=

# FastAPI backend / Ollama runtime
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_SPEED=llama3.2:latest
OLLAMA_MODEL_BALANCED=qwen3:8b
OLLAMA_KEEP_ALIVE=10m
OLLAMA_TIMEOUT_SPEED=24
OLLAMA_TIMEOUT_BALANCED=42
OLLAMA_NUM_CTX_SPEED=4096
OLLAMA_NUM_CTX_BALANCED=6144
OLLAMA_NUM_CTX_MULTIMODAL=6144
OLLAMA_MAX_TOKENS_SPEED=180
OLLAMA_MAX_TOKENS_BALANCED=360
OLLAMA_MAX_TOKENS_DIRECT=420
OLLAMA_MAX_TOKENS_MULTIMODAL=480
# Optional hardware tuning. Leave empty unless you know your machine's best values.
OLLAMA_NUM_THREAD=
OLLAMA_NUM_GPU=

# Local OpenAI-compatible open-source runtime (optional)
# Works with vLLM, Hugging Face TGI, LM Studio, llama.cpp server, or a private GPU endpoint.
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_OPENAI_API_KEY=
LOCAL_OPENAI_MODEL_SPEED=Qwen/Qwen3-8B
LOCAL_OPENAI_MODEL_BALANCED=openai/gpt-oss-20b
LOCAL_OPENAI_DECK_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Server-side open-source endpoint for public deployments (optional)
OPEN_SOURCE_BASE_URL=
OPEN_SOURCE_API_KEY=
OPEN_SOURCE_REQUIRES_API_KEY=true
OPEN_SOURCE_MODEL_SPEED=Qwen/Qwen2.5-VL-7B-Instruct
OPEN_SOURCE_MODEL_BALANCED=Qwen/Qwen2.5-VL-7B-Instruct
OPEN_SOURCE_DECK_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Dedicated deck-review runtime. Leave as vertex until an open-source vision endpoint is ready.
SIFT_DECK_REVIEW_PROVIDER=vertex
SIFT_DECK_REVIEW_MODEL=gemini-2.5-flash
SIFT_DECK_REVIEW_MAX_TOKENS=2600
SIFT_DECK_REVIEW_TIMEOUT_SECONDS=52

# Hosted Groq runtime (recommended for deployed MVP)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_SPEED=openai/gpt-oss-20b
GROQ_MODEL_BALANCED=openai/gpt-oss-120b

# Local API-key-first mode (optional)
# Set SIFT_MODEL_PROVIDER to one of: ollama, local_openai, groq, openai, openrouter, anthropic, gemini, cerebras, vertex
# Then either enter the key in the UI or export the provider-specific env key above / below.

# Optional OAuth sign-in
# Local callbacks:
# - http://127.0.0.1:7860/api/auth/callback/google
# - http://127.0.0.1:7860/api/auth/callback/apple
# - http://127.0.0.1:7860/api/auth/callback/linkedin
# - http://127.0.0.1:7860/api/auth/callback/x
# If you run the split dev stack, use port 8000 for the backend callback URLs.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
# OAuth 1.0a aliases accepted for X/Twitter:
X_OAUTH_CONSUMER_KEY=
X_OAUTH_CONSUMER_SECRET=

# Optional legacy Gradio prototype config
# ANTHROPIC_API_KEY=
# OLLAMA_MODEL=gemma3:12b

# Runtime mode
VK_MODEL_PROVIDER=ollama
VK_DATA_DIR=data
VK_ADMIN_TOKEN=
VK_SESSION_SECRET=change-me-for-shared-use
VK_COOKIE_SECURE=false

# FastAPI backend / Ollama runtime
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_SPEED=llama3.2:latest
OLLAMA_MODEL_BALANCED=qwen3:4b
OLLAMA_TIMEOUT_SPEED=30
OLLAMA_TIMEOUT_BALANCED=45

# Hosted Groq runtime (recommended for deployed MVP)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_SPEED=llama-3.1-8b-instant
GROQ_MODEL_BALANCED=llama-3.3-70b-versatile

# Optional OAuth for Google / Apple sign-in
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=

# Optional legacy Gradio prototype config
# ANTHROPIC_API_KEY=
# OLLAMA_MODEL=gemma3:12b
